{"model": "Qwen 3.5 9B", "runtime": "llamacpp", "prompt_name": "code_caesar_cipher__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 373.1, "generation_tps": 61.4, "peak_memory_gb": 0.0, "wall_time_sec": 26.9, "output": "def caesar_cipher(text: str, shift: int) -> str:\n    result = []\n    for char in text:\n        if 'a' <= char <= 'z':\n            base = ord('a')\n            shifted = (ord(char) - base + shift) % 26\n            result.append(chr(base + shifted))\n        elif 'A' <= char <= 'Z':\n            base = ord('A')\n            shifted = (ord(char) - base + shift) % 26\n            result.append(chr(base + shifted))\n        else:\n            result.append(char)\n    return ''.join(result)", "error": null, "prompt_hash": "b99f92972301"}
