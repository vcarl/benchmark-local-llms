{"model": "Qwen 3.5 35B-A3B (MoE)", "runtime": "llamacpp", "prompt_name": "code_caesar_cipher__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 554.3, "generation_tps": 82.0, "peak_memory_gb": 0.0, "wall_time_sec": 16.6, "output": "def caesar_cipher(text: str, shift: int) -> str:\n    result = []\n    for char in text:\n        if 'a' <= char <= 'z':\n            shifted = chr((ord(char) - ord('a') + shift) % 26 + ord('a'))\n            result.append(shifted)\n        elif 'A' <= char <= 'Z':\n            shifted = chr((ord(char) - ord('A') + shift) % 26 + ord('A'))\n            result.append(shifted)\n        else:\n            result.append(char)\n    return ''.join(result)", "error": null, "prompt_hash": "b99f92972301"}
