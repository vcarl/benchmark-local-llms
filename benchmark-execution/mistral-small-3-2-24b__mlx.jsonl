{"model": "Mistral Small 3.2 24B", "runtime": "mlx", "prompt_name": "code_matrix_rotate__t3_direct", "prompt_tokens": 80, "generation_tokens": 78, "prompt_tps": 308.96838633440876, "generation_tps": 39.69810187981097, "peak_memory_gb": 13.529393836, "wall_time_sec": 2.2703990409936523, "output": "def rotate_90(matrix: list[list[int]]) -> list[list[int]]:\n    n = len(matrix)\n    rotated = [[0 for _ in range(n)] for _ in range(n)]\n    for i in range(n):\n        for j in range(n):\n            rotated[j][n - i - 1] = matrix[i][j]\n    return rotated", "error": null, "prompt_hash": "423335f26fd2", "quant": "4bit"}
{"model": "Mistral Small 3.2 24B", "runtime": "mlx", "prompt_name": "code_lru_cache__t3_direct", "prompt_tokens": 112, "generation_tokens": 120, "prompt_tps": 503.96157215716914, "generation_tps": 39.74451069310022, "peak_memory_gb": 13.529393836, "wall_time_sec": 3.287312792002922, "output": "def LRUCache(self, capacity: int):\n        self.capacity = capacity\n        self.cache = {}\n\n    def get(self, key: int) -> int:\n        if key in self.cache:\n            value = self.cache.pop(key)\n            self.cache[key] = value\n            return value\n        return -1\n\n    def put(self, key: int, value: int):\n        if key in self.cache:\n            self.cache.pop(key)\n        elif len(self.cache) >= self.capacity:\n            self.cache.pop(next(iter(self.cache)))\n        self.cache[key] = value", "error": null, "prompt_hash": "e594f8996a66", "quant": "4bit"}
