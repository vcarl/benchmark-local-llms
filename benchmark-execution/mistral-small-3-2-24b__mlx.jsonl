{"model": "Mistral Small 3.2 24B", "runtime": "mlx", "prompt_name": "code_two_sum__t1_direct", "prompt_tokens": 79, "generation_tokens": 67, "prompt_tps": 468.43846341298126, "generation_tps": 41.381682931829246, "peak_memory_gb": 13.426633128, "wall_time_sec": 1.8345854579965817, "output": "def two_sum(nums: list[int], target: int) -> list[int]:\n    num_dict = {}\n    for i, num in enumerate(nums):\n        complement = target - num\n        if complement in num_dict:\n            return [num_dict[complement], i]\n        num_dict[num] = i\n    return []", "error": null, "prompt_hash": "83f3800e6663", "quant": "4bit"}
