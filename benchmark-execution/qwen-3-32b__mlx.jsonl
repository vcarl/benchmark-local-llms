{"model": "Qwen 3 32B", "runtime": "mlx", "prompt_name": "code_lru_cache__t3_direct", "prompt_tokens": 121, "generation_tokens": 4241, "prompt_tps": 371.06448357775713, "generation_tps": 25.48474051366147, "peak_memory_gb": 19.786932916, "wall_time_sec": 166.79717325000092, "output": "from collections import OrderedDict\n\nclass LRUCache:\n    def __init__(self, capacity: int):\n        self.cache = OrderedDict()\n        self.capacity = capacity\n\n    def get(self, key: int) -> int:\n        if key in self.cache:\n            self.cache.move_to_end(key, last=True)\n            return self.cache[key]\n        return -1\n\n    def put(self, key: int, value: int) -> None:\n        if key in self.cache:\n            self.cache.pop(key)\n        else:\n            if len(self.cache) >= self.capacity:\n                self.cache.popitem(last=False)\n        self.cache[key] = value", "error": null, "prompt_hash": "e594f8996a66"}
