{"model": "Qwen 3 32B", "runtime": "llamacpp", "prompt_name": "code_caesar_cipher__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 78.3, "generation_tps": 18.9, "peak_memory_gb": 0.0, "wall_time_sec": 123.8, "output": "def caesar_cipher(text: str, shift: int) -> str:\n    shifted = []\n    for char in text:\n        if char.islower():\n            base = ord('a')\n            original = ord(char) - base\n            new_pos = (original + shift) % 26\n            shifted.append(chr(base + new_pos))\n        elif char.isupper():\n            base = ord('A')\n            original = ord(char) - base\n            new_pos = (original + shift) % 26\n            shifted.append(chr(base + new_pos))\n        else:\n            shifted.append(char)\n    return ''.join(shifted)", "error": null, "prompt_hash": "b99f92972301"}
