{"model": "DeepSeek R1-0528 Qwen3 8B", "runtime": "llamacpp", "prompt_name": "code_caesar_cipher__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 198.0, "generation_tps": 58.3, "peak_memory_gb": 0.0, "wall_time_sec": 74.3, "output": "def caesar_cipher(text: str, shift: int) -> str:\n    result = []\n    for char in text:\n        if char.islower():\n            base = 'a'\n            offset = 97\n            shifted_char = chr((ord(char) - offset + shift) % 26 + offset)\n        elif char.isupper():\n            base = 'A'\n            offset = 65\n            shifted_char = chr((ord(char) - offset + shift) % 26 + offset)\n        else:\n            shifted_char = char\n        result.append(shifted_char)\n    return ''.join(result)", "error": null, "prompt_hash": "b99f92972301"}
{"model": "DeepSeek R1-0528 Qwen3 8B", "runtime": "llamacpp", "prompt_name": "code_caesar_cipher__t2_bugfix", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 446.6, "generation_tps": 74.6, "peak_memory_gb": 0.0, "wall_time_sec": 5.0, "output": "```python\ndef caesar_cipher(text: str, shift: int) -> str:\n    result = ''\n    for char in text:\n        if char.isalpha():\n            base = ord('a') if char.islower() else ord('A')\n            result += chr((ord(char) - base + shift) % 26 + base)\n        else:\n            result += char\n    return result", "error": null, "prompt_hash": "a65231b12406"}
{"model": "DeepSeek R1-0528 Qwen3 8B", "runtime": "llamacpp", "prompt_name": "code_fibonacci__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 318.0, "generation_tps": 59.6, "peak_memory_gb": 0.0, "wall_time_sec": 4.3, "output": "def fibonacci(n: int) -> int:\n    if n < 0:\n        raise ValueError(\"n must be a non-negative integer\")\n    elif n == 0:\n        return 0\n    elif n == 1:\n        return 1\n    else:\n        a, b = 0, 1\n        for _ in range(n - 1):\n            a, b = b, a + b\n        return a", "error": null, "prompt_hash": "85bb99bf2d1c"}
