{"model": "Qwen 2.5 72B Instruct", "runtime": "mlx", "prompt_name": "code_caesar_cipher__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 93.7, "generation_tps": 11.3, "peak_memory_gb": 0.0, "wall_time_sec": 10.4, "output": "def caesar_cipher(text: str, shift: int) -> str:\n    def shift_char(c, shift):\n        if c.islower():\n            return chr((ord(c) - ord('a') + shift) % 26 + ord('a'))\n        elif c.isupper():\n            return chr((ord(c) - ord('A') + shift) % 26 + ord('A'))\n        else:\n            return c\n    return ''.join(shift_char(c, shift) for c in text)", "error": null, "prompt_hash": "b99f92972301"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "mlx", "prompt_name": "code_caesar_cipher__t2_bugfix", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 107.4, "generation_tps": 11.6, "peak_memory_gb": 0.0, "wall_time_sec": 8.2, "output": "def caesar_cipher(text: str, shift: int) -> str:\n    result = ''\n    for char in text:\n        if char.isalpha():\n            base = ord('a') if char.islower() else ord('A')\n            result += chr((ord(char) - base + shift) % 26 + base)\n        else:\n            result += char\n    return result", "error": null, "prompt_hash": "a65231b12406"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "mlx", "prompt_name": "code_fibonacci__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 85.2, "generation_tps": 10.4, "peak_memory_gb": 0.0, "wall_time_sec": 6.8, "output": "def fibonacci(n: int) -> int:\n    if n <= 1:\n        return n\n    a, b = 0, 1\n    for _ in range(2, n + 1):\n        a, b = b, a + b\n    return b", "error": null, "prompt_hash": "85bb99bf2d1c"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "mlx", "prompt_name": "code_fibonacci__t2_docstring", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 106.1, "generation_tps": 11.5, "peak_memory_gb": 0.0, "wall_time_sec": 9.2, "output": "def fibonacci(n: int) -> int:\n    \"\"\"Return the nth Fibonacci number.\n\n    fibonacci(0) = 0\n    fibonacci(1) = 1\n    fibonacci(n) = fibonacci(n-1) + fibonacci(n-2)\n    \"\"\"\n    if n == 0:\n        return 0\n    elif n == 1:\n        return 1\n    else:\n        return fibonacci(n-1) + fibonacci(n-2)", "error": null, "prompt_hash": "529a97de5cfa"}
