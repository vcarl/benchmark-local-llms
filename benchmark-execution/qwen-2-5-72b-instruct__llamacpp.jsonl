{"model": "Qwen 2.5 72B Instruct", "runtime": "llamacpp", "prompt_name": "code_caesar_cipher__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 51.8, "generation_tps": 11.0, "peak_memory_gb": 0.0, "wall_time_sec": 11.1, "output": "def caesar_cipher(text: str, shift: int) -> str:\n    def shift_char(c: str, shift: int) -> str:\n        if c.islower():\n            return chr((ord(c) - ord('a') + shift) % 26 + ord('a'))\n        elif c.isupper():\n            return chr((ord(c) - ord('A') + shift) % 26 + ord('A'))\n        else:\n            return c\n    return ''.join(shift_char(c, shift) for c in text)", "error": null, "prompt_hash": "b99f92972301"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "llamacpp", "prompt_name": "code_caesar_cipher__t2_bugfix", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 59.9, "generation_tps": 7.7, "peak_memory_gb": 0.0, "wall_time_sec": 12.5, "output": "def caesar_cipher(text: str, shift: int) -> str:\n    result = ''\n    for char in text:\n        if char.isalpha():\n            base = ord('a') if char.islower() else ord('A')\n            result += chr((ord(char) - base + shift) % 26 + base)\n        else:\n            result += char\n    return result", "error": null, "prompt_hash": "a65231b12406"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "llamacpp", "prompt_name": "code_fibonacci__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 35.1, "generation_tps": 6.5, "peak_memory_gb": 0.0, "wall_time_sec": 8.0, "output": "def fibonacci(n: int) -> int:\n    if n <= 0:\n        return 0\n    elif n == 1:\n        return 1\n    else:\n        a, b = 0, 1\n        for _ in range(2, n + 1):\n            a, b = b, a + b\n        return b", "error": null, "prompt_hash": "85bb99bf2d1c"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "llamacpp", "prompt_name": "code_fibonacci__t2_docstring", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 56.4, "generation_tps": 8.4, "peak_memory_gb": 0.0, "wall_time_sec": 13.3, "output": "def fibonacci(n: int) -> int:\n    \"\"\"Return the nth Fibonacci number.\n\n    fibonacci(0) = 0\n    fibonacci(1) = 1\n    fibonacci(n) = fibonacci(n-1) + fibonacci(n-2)\n    \"\"\"\n    if n == 0:\n        return 0\n    elif n == 1:\n        return 1\n    else:\n        return fibonacci(n - 1) + fibonacci(n - 2)", "error": null, "prompt_hash": "529a97de5cfa"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "llamacpp", "prompt_name": "code_flatten__t3_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 41.9, "generation_tps": 9.3, "peak_memory_gb": 0.0, "wall_time_sec": 5.4, "output": "def flatten(lst: list) -> list:\n    result = []\n    for item in lst:\n        if isinstance(item, list):\n            result.extend(flatten(item))\n        else:\n            result.append(item)\n    return result", "error": null, "prompt_hash": "4920078c1199"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "llamacpp", "prompt_name": "code_is_palindrome__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 73.8, "generation_tps": 12.0, "peak_memory_gb": 0.0, "wall_time_sec": 4.2, "output": "def is_palindrome(s: str) -> bool:\n    s = ''.join(c for c in s.lower() if c.isalnum())\n    return s == s[::-1]", "error": null, "prompt_hash": "3a8c67a06ee6"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "llamacpp", "prompt_name": "code_is_palindrome__t2_tdd", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 66.9, "generation_tps": 8.8, "peak_memory_gb": 0.0, "wall_time_sec": 5.3, "output": "def is_palindrome(s):\n    s = ''.join(c.lower() for c in s if c.isalnum())\n    return s == s[::-1]", "error": null, "prompt_hash": "cff7669d8a80"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "llamacpp", "prompt_name": "code_lru_cache__t3_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 43.7, "generation_tps": 9.0, "peak_memory_gb": 0.0, "wall_time_sec": 16.8, "output": "def __init__(self, capacity: int):\n    self.capacity = capacity\n    self.cache = {}\n    self.order = []\n\ndef get(self, key: int) -> int:\n    if key in self.cache:\n        self.order.remove(key)\n        self.order.append(key)\n        return self.cache[key]\n    return -1\n\ndef put(self, key: int, value: int):\n    if key in self.cache:\n        self.order.remove(key)\n    elif len(self.cache) >= self.capacity:\n        lru_key = self.order.pop(0)\n        del self.cache[lru_key]\n    self.cache[key] = value\n    self.order.append(key)", "error": null, "prompt_hash": "e594f8996a66"}
{"model": "Qwen 2.5 72B Instruct", "runtime": "llamacpp", "prompt_name": "code_matrix_rotate__t3_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 29.4, "generation_tps": 8.9, "peak_memory_gb": 0.0, "wall_time_sec": 9.3, "output": "def rotate_90(matrix: list[list[int]]) -> list[list[int]]:\n    n = len(matrix)\n    rotated = [[0] * n for _ in range(n)]\n    for i in range(n):\n        for j in range(n):\n            rotated[j][n - 1 - i] = matrix[i][j]\n    return rotated", "error": null, "prompt_hash": "423335f26fd2"}
