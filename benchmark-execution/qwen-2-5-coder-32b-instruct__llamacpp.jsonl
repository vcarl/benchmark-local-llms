{"model": "Qwen 2.5 Coder 32B Instruct", "runtime": "llamacpp", "prompt_name": "code_caesar_cipher__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 70.1, "generation_tps": 21.3, "peak_memory_gb": 0.0, "wall_time_sec": 5.5, "output": "def caesar_cipher(text: str, shift: int) -> str:\n    result = []\n    for char in text:\n        if 'a' <= char <= 'z':\n            base = ord('a')\n        elif 'A' <= char <= 'Z':\n            base = ord('A')\n        else:\n            result.append(char)\n            continue\n        shifted = (ord(char) - base + shift) % 26 + base\n        result.append(chr(shifted))\n    return ''.join(result)", "error": null, "prompt_hash": "b99f92972301"}
