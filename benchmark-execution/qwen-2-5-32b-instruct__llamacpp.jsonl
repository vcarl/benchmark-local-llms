{"model": "Qwen 2.5 32B Instruct", "runtime": "llamacpp", "prompt_name": "code_matrix_rotate__t3_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 60.6, "generation_tps": 21.4, "peak_memory_gb": 0.0, "wall_time_sec": 4.0, "output": "def rotate_90(matrix: list[list[int]]) -> list[list[int]]:\n    n = len(matrix)\n    rotated = [[0] * n for _ in range(n)]\n    for i in range(n):\n        for j in range(n):\n            rotated[j][n - 1 - i] = matrix[i][j]\n    return rotated", "error": null, "prompt_hash": "423335f26fd2"}
{"model": "Qwen 2.5 32B Instruct", "runtime": "llamacpp", "prompt_name": "code_lru_cache__t3_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 98.6, "generation_tps": 21.6, "peak_memory_gb": 0.0, "wall_time_sec": 7.9, "output": "def __init__(self, capacity: int):\n    self.capacity = capacity\n    self.cache = {}\n    self.usage = []\n\ndef get(self, key: int) -> int:\n    if key in self.cache:\n        self.usage.remove(key)\n        self.usage.append(key)\n        return self.cache[key]\n    return -1\n\ndef put(self, key: int, value: int):\n    if key in self.cache:\n        self.cache[key] = value\n        self.usage.remove(key)\n        self.usage.append(key)\n    else:\n        if len(self.cache) >= self.capacity:\n            lru_key = self.usage.pop(0)\n            del self.cache[lru_key]\n        self.cache[key] = value\n        self.usage.append(key)", "error": null, "prompt_hash": "e594f8996a66"}
