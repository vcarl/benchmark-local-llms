{"model": "DeepSeek R1 Distill Qwen 7B", "runtime": "llamacpp", "prompt_name": "code_caesar_cipher__t1_direct", "prompt_tokens": 0, "generation_tokens": 0, "prompt_tps": 298.8, "generation_tps": 78.3, "peak_memory_gb": 0.0, "wall_time_sec": 15.0, "output": "```python\ndef caesar_cipher(text: str, shift: int) -> str:\n    result = []\n    for c in text:\n        if c.islower():\n            new_pos = (ord(c) - ord('a') + shift) % 26\n            result.append(chr(new_pos + ord('a')))\n        elif c.isupper():\n            new_pos = (ord(c) - ord('A') + shift) % 26\n            result.append(chr(new_pos + ord('A')))\n        else:\n            result.append(c)\n    return ''.join(result)", "error": null, "prompt_hash": "b99f92972301"}
