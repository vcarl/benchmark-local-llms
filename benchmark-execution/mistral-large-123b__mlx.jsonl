{"model": "Mistral Large 123B", "runtime": "mlx", "prompt_name": "code_fibonacci", "prompt_tokens": 92, "generation_tokens": 83, "prompt_tps": 57.75285676998342, "generation_tps": 6.7902793849057534, "peak_memory_gb": 76.814696868, "wall_time_sec": 13.8328975000004, "output": " def fibonacci(n: int) -> int:\n    if n <= 0:\n        return 0\n    elif n == 1:\n        return 1\n    else:\n        a, b = 0, 1\n        for _ in range(2, n + 1):\n            a, b = b, a + b\n        return b", "error": null, "prompt_hash": "85bb99bf2d1c"}
{"model": "Mistral Large 123B", "runtime": "mlx", "prompt_name": "code_two_sum", "prompt_tokens": 89, "generation_tokens": 93, "prompt_tps": 57.052274066038464, "generation_tps": 6.851807961411176, "peak_memory_gb": 76.814696868, "wall_time_sec": 15.149440750003123, "output": " def two_sum(nums: list[int], target: int) -> list[int]:\n    num_to_index = {}\n    for i, num in enumerate(nums):\n        complement = target - num\n        if complement in num_to_index:\n            return [num_to_index[complement], i]\n        num_to_index[num] = i\n    return []", "error": null, "prompt_hash": "83f3800e6663"}
