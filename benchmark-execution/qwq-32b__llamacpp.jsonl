{"model": "QwQ 32B", "runtime": "llamacpp", "prompt_name": "code_fibonacci__t1_direct", "prompt_tokens": 85, "generation_tokens": 1454, "prompt_tps": 115.39173977340707, "generation_tps": 19.04938785696116, "peak_memory_gb": 0.0, "wall_time_sec": 76.67025349999312, "output": "def fibonacci(n: int) -> int:\n    if n == 0:\n        return 0\n    elif n == 1:\n        return 1\n    a, b = 0, 1\n    for i in range(2, n + 1):\n        c = a + b\n        a = b\n        b = c\n    return b", "error": null, "prompt_hash": "85bb99bf2d1c"}
