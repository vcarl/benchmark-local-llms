{"model": "Mistral Small 3.2 24B", "runtime": "llamacpp", "prompt_name": "code_matrix_rotate__t3_direct", "prompt_tokens": 80, "generation_tokens": 78, "prompt_tps": 117.90386055478547, "generation_tps": 34.27973228408054, "peak_memory_gb": 0.0, "wall_time_sec": 2.5937907909974456, "output": "def rotate_90(matrix: list[list[int]]) -> list[list[int]]:\n    n = len(matrix)\n    rotated = [[0 for _ in range(n)] for _ in range(n)]\n    for i in range(n):\n        for j in range(n):\n            rotated[j][n - 1 - i] = matrix[i][j]\n    return rotated</s>", "error": null, "prompt_hash": "423335f26fd2"}
{"model": "Mistral Small 3.2 24B", "runtime": "llamacpp", "prompt_name": "code_lru_cache__t3_direct", "prompt_tokens": 112, "generation_tokens": 120, "prompt_tps": 132.6148472594488, "generation_tps": 34.08705492958467, "peak_memory_gb": 0.0, "wall_time_sec": 4.061401291008224, "output": "def LRUCache(self, capacity: int):\n    self.capacity = capacity\n    self.cache = {}\n\n    def get(self, key: int) -> int:\n        if key in self.cache:\n            value = self.cache.pop(key)\n            self.cache[key] = value\n            return value\n        return -1\n\n    def put(self, key: int, value: int):\n        if key in self.cache:\n            self.cache.pop(key)\n        elif len(self.cache) >= self.capacity:\n            self.cache.pop(next(iter(self.cache)))\n        self.cache[key] = value</s>", "error": null, "prompt_hash": "e594f8996a66"}
