{"model": "Mistral Large 123B", "runtime": "llamacpp", "prompt_name": "code_fibonacci", "prompt_tokens": 92, "generation_tokens": 83, "prompt_tps": 26.160874261536655, "generation_tps": 6.44810290985793, "peak_memory_gb": 0.0, "wall_time_sec": 14.598847707999084, "output": "def fibonacci(n: int) -> int:\n    if n <= 0:\n        return 0\n    elif n == 1:\n        return 1\n    else:\n        a, b = 0, 1\n        for _ in range(2, n + 1):\n            a, b = b, a + b\n        return b", "error": null, "prompt_hash": "85bb99bf2d1c"}
{"model": "Mistral Large 123B", "runtime": "llamacpp", "prompt_name": "code_two_sum", "prompt_tokens": 89, "generation_tokens": 73, "prompt_tps": 24.689340494809656, "generation_tps": 6.4857290416997735, "peak_memory_gb": 0.0, "wall_time_sec": 12.965247041000111, "output": "def two_sum(nums, target):\n    prev_map = {}\n    for i, num in enumerate(nums):\n        diff = target - num\n        if diff in prev_map:\n            return [prev_map[diff], i]\n        prev_map[num] = i\n    return []", "error": null, "prompt_hash": "83f3800e6663"}
{"model": "Mistral Large 123B", "runtime": "llamacpp", "prompt_name": "code_caesar_cipher", "prompt_tokens": 93, "generation_tokens": 171, "prompt_tps": 23.46243281965907, "generation_tps": 6.156829792892167, "peak_memory_gb": 0.0, "wall_time_sec": 29.740431583999452, "output": "```python\ndef caesar_cipher(text: str, shift: int) -> str:\n    result = []\n    shift = shift % 26\n    for char in text:\n        if 'a' <= char <= 'z':\n            new_char = chr(((ord(char) - ord('a') + shift) % 26) + ord('a'))\n            result.append(new_char)\n        elif 'A' <= char <= 'Z':\n            new_char = chr(((ord(char) - ord('A') + shift) % 26) + ord('A'))\n            result.append(new_char)\n        else:\n            result.append(char)\n    return ''.join(result)\n```", "error": null, "prompt_hash": "b99f92972301"}
